{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "1PromptApps Manifest",
  "description": "Manifest for a 1PromptApps submission (v1.0)",
  "type": "object",
  "required": [
    "manifestVersion", "name", "slug", "tagline", "category",
    "prompt", "outcome", "demo", "source", "author", "media",
    "permissions", "manualEditLevel"
  ],
  "additionalProperties": true,
  "properties": {
    "manifestVersion": { "type": "string", "const": "1.0" },
    "name": { "type": "string", "minLength": 3, "maxLength": 60 },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,79}$",
      "description": "URL-safe slug, must match the folder name"
    },
    "tagline": { "type": "string", "minLength": 10, "maxLength": 120 },
    "description": { "type": "string", "maxLength": 2000 },
    "category": {
      "type": "string",
      "enum": [
        "productivity", "developer-tools", "design-tools", "education", "finance",
        "data-visualization", "internal-tools", "games", "writing",
        "personal-utilities", "ecommerce", "health-fitness", "other"
      ]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 8,
      "uniqueItems": true
    },
    "prompt": {
      "type": "object",
      "required": ["text", "builder", "followUpCount"],
      "properties": {
        "text": { "type": "string", "minLength": 10, "maxLength": 8000 },
        "model": { "type": "string" },
        "builder": {
          "type": "string",
          "enum": ["v0", "lovable", "bolt", "replit", "cursor", "claude", "chatgpt", "windsurf", "glm", "other"]
        },
        "followUpCount": { "type": "integer", "minimum": 0 },
        "transcriptUrl": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "outcome": {
      "type": "object",
      "required": ["reproducibility"],
      "properties": {
        "timeToFirstVersionMinutes": { "type": "integer", "minimum": 0 },
        "reproducibility": { "type": "string", "enum": ["full", "partial", "none"] },
        "worked": { "type": "array", "items": { "type": "string" } },
        "manualEdits": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "demo": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["bundle", "live"] },
        "entry": { "type": "string" },
        "liveUrl": { "type": "string", "format": "uri" }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": ["available"],
      "properties": {
        "available": { "type": "boolean" },
        "url": { "type": "string", "format": "uri" },
        "license": { "type": "string" }
      },
      "additionalProperties": false
    },
    "author": {
      "type": "object",
      "required": ["name", "handle"],
      "properties": {
        "name": { "type": "string" },
        "handle": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "contactEmail": { "type": "string", "format": "email" }
      },
      "additionalProperties": false
    },
    "media": {
      "type": "object",
      "required": ["thumbnail", "screenshots"],
      "properties": {
        "thumbnail": { "type": "string" },
        "screenshots": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["src", "alt"],
            "properties": {
              "src": { "type": "string" },
              "alt": { "type": "string", "minLength": 5 }
            }
          }
        }
      },
      "additionalProperties": false
    },
    "permissions": {
      "type": "object",
      "required": ["permissionToFeature", "rightsAttested"],
      "properties": {
        "permissionToFeature": { "type": "boolean", "const": true },
        "rightsAttested": { "type": "boolean", "const": true }
      },
      "additionalProperties": false
    },
    "manualEditLevel": {
      "type": "string",
      "enum": ["none-claimed", "minor", "moderate", "significant", "unknown"]
    },
    "externalApiDomains": {
      "type": "array",
      "items": { "type": "string" }
    },
    "publishedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  }
}
